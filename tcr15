local function trsp(v)
	for _,x in ipairs(chr:GetDescendants()) do
		if x:IsA("BasePart") and x.Name ~= "HumanoidRootPart" then
			x.Transparency = v
		end
	end
end

local function clearhl()
	for _,v in pairs(hl) do
		if v then v:Destroy() end
	end
	hl = {}
end

local function addhl(p)
	if p == plr then return end
	if hl[p] then return end

	local c = p.Character
	if not c then return end

	local h = Instance.new("Highlight")
	h.FillTransparency = 1
	h.OutlineColor = Color3.fromRGB(255,0,0)
	h.OutlineTransparency = 0
	h.Parent = c

	hl[p] = h
end

local function nc(v)
	for _,x in ipairs(chr:GetDescendants()) do
		if x:IsA("BasePart") then
			if v then
				x.CanCollide = false
			else
				if x.Name == "UpperTorso" or x.Name == "LowerTorso" or x.Name == "Head" then
					x.CanCollide = true
				else
					x.CanCollide = false
				end
			end
		end
	end
end

