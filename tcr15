local function prt()
	local c1 = Instance.new("Part")
	c1.Shape = Enum.PartType.Ball
	c1.Material = Enum.Material.Neon
	c1.Color = Color3.new(0,0,0)
	c1.Size = Vector3.new(1,1,1)
	c1.Transparency = 0
	c1.CanCollide = false
	c1.Anchored = true
	c1.Massless = true
	c1.CFrame = hrp.CFrame
	c1.Parent = workspace

	local c2 = Instance.new("Part")
	c2.Shape = Enum.PartType.Ball
	c2.Material = Enum.Material.Neon
	c2.Color = Color3.fromRGB(140,0,0)
	c2.Size = Vector3.new(2,2,2)
	c2.Transparency = 0
	c2.CanCollide = false
	c2.Anchored = true
	c2.Massless = true
	c2.CFrame = hrp.CFrame
	c2.Parent = workspace

	ts:Create(c1,TweenInfo.new(0.75),{Transparency = 1,Size = Vector3.new(10,10,10)}):Play()
	ts:Create(c2,TweenInfo.new(0.75),{Transparency = 1,Size = Vector3.new(20,20,20)}):Play()

	task.delay(1,function()
		c1:Destroy()
		c2:Destroy()
	end)
	for _,x in ipairs(chr:GetDescendants()) do
		if x:IsA("BasePart") and x.Name ~= "HumanoidRootPart" then
			for i = 1,10 do
				local p = Instance.new("Part")
				p.Shape = Enum.PartType.Ball
				p.Material = Enum.Material.SmoothPlastic
				p.Size = Vector3.new(
					math.random(10,20)/100,
					math.random(10,20)/100,
					math.random(10,20)/100
				)
				p.Transparency = 0.5
				p.CanCollide = false
				p.Anchored = false
				p.Massless = true
				p.Position = x.Position + Vector3.new(
					math.random(-20,20)/10,
					math.random(-20,20)/10,
					math.random(-20,20)/10
				)

				local c = math.random(1,3)

				if c == 1 then
					p.Color = Color3.new(0,0,0)
				elseif c == 2 then
					p.Color = Color3.fromRGB(60,0,0)
				else
					p.Color = Color3.fromRGB(140,0,0)
				end

				local f = Instance.new("BodyForce")
				f.Force = Vector3.new(0,p:GetMass() * workspace.Gravity,0)
				f.Parent = p

				p.Parent = workspace

				local bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(999999,999999,999999)
				bv.Velocity = Vector3.new(
					math.random(-40,40),
					math.random(-20,40),
					math.random(-40,40)
				)
				bv.Parent = p

				task.delay(0.2,function()
					bv:Destroy()
				end)

				task.delay(1.5,function()
					ts:Create(p,TweenInfo.new(0.4),{
						Transparency = 1,
						Size = Vector3.new(0,0,0)
					}):Play()

					task.wait(0.4)

					p:Destroy()
				end)
			end
		end
	end
end

local function mkp(a,b,t)
	local p0 = chr:FindFirstChild(a)
	local p1 = chr:FindFirstChild(b)

	if not p0 or not p1 then
		return
	end

	local a0 = Instance.new("Attachment")
	local a1 = Instance.new("Attachment")

	a0.Parent = p0
	a1.Parent = p1

	local rp = Instance.new("RopeConstraint")
	rp.Attachment0 = a0
	rp.Attachment1 = a1
	rp.Visible = true
	rp.Color = BrickColor.new("Really black")
	rp.Length = 1
	rp.Thickness = t
	rp.Restitution = 0
	rp.Parent = chr
end

local function mkani(id)
	local an = Instance.new("Animation")
	an.AnimationId = "rbxassetid://"..id
	local tr = h:LoadAnimation(an)
	tr.Priority = Enum.AnimationPriority.Action
	return tr
end

local function mksnd(id, lp, vol)
	local s = Instance.new("Sound")
	s.SoundId = "rbxassetid://"..id
	s.Volume = vol or 1
	s.Looped = lp or false
	s.Parent = hrp
	return s
end

local function stpall()
	for _,v in ipairs(h:GetPlayingAnimationTracks()) do
		v:Stop(0.1)
	end
