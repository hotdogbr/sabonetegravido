local function key(a,s,i)
	if s ~= Enum.UserInputState.Begin then
		return
	end

	local k = i.KeyCode

	if k == Enum.KeyCode.F then
		if not l then
			l = true
			z = false
			mus:Stop()
			hb:Play()
			s1:Play()
			stpall()
			lk:Play(0.2)
			trsp(0.75)
			nc(true)

			particle.Enabled = true
			hum.WalkSpeed = 115

			task.spawn(function()
				while l do
					for _,p in ipairs(game.Players:GetPlayers()) do
						if p ~= plr then
							addhl(p)
						end
					end
					task.wait(1)
				end
			end)
		else
			l = false
			z = false
			hb:Stop()
			nc(false)
			trsp(0)
			stpall()
			i1:Play(0.2)
			mus:Play()
			particle.Enabled = false
			hum.WalkSpeed = 19
		end
	end

	if k == Enum.KeyCode.T then
		if not tnt then
			tnt = true
			stpall()
			trsp(0)
			nc(true)
			particle.Enabled = false
			hum.WalkSpeed = 18

			tn:Play(0.1)

			task.spawn(function()
				while tnt and l do
					local near = nil
					local dist = math.huge

					for _,p in ipairs(game.Players:GetPlayers()) do
						if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
							local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
							if d < dist then
								dist = d
								near = p
							end
						end
					end

					if not tnt then break end

					if near and dist <= 10 then
						tnt = false
						stpall()

						lk:Play(0.15)

						trsp(0.75)
						nc(true)

						particle.Enabled = true
						hum.WalkSpeed = 115
						break
					end

					rs.RenderStepped:Wait()
				end
			end)
		else
			tnt = false
			stpall()

			lk:Play(0.15)

			trsp(0.75)
			nc(true)

			particle.Enabled = true
			hum.WalkSpeed = 115
		end
	end

	if k == Enum.KeyCode.Z then
		z = true
		hb:Stop()
		s2:Play()
		trsp(0)
		stpall()
		zh:Play(0.15)
		particle.Enabled = false
		hum.WalkSpeed = 2.5

		local st = tick()

		task.spawn(function()
			while l and z do
				local np = nil
				local nd = math.huge

				for _,p in ipairs(game.Players:GetPlayers()) do
					if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
						local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
						if d < nd then
							nd = d
							np = p
						end
					end
				end

				if np and np.Character and np.Character:FindFirstChild("HumanoidRootPart") then
					local ps = np.Character.HumanoidRootPart.Position
					hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(ps.X, hrp.Position.Y, ps.Z))

					if nd <= 27 then
						z = false
						stpall()
						lk:Play(0.15)
						trsp(0.75)
						hb:Play()
						particle.Enabled = true
						hum.WalkSpeed = 115
						st = tick()
						break
					end
				end

				if tick() - st >= 7 then
					z = false
					stpall()
					lk:Play(0.15)
					trsp(0.75)
