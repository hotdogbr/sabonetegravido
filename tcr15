rs.RenderStepped:Connect(function(dt)
	if l then
		nc(true)
		return
	end

	mv = hum.MoveDirection.Magnitude > 0.05

	if c and mv then
		hum.WalkSpeed = 37
		ts:Create(cam,TweenInfo.new(0.25),{FieldOfView=85}):Play()

		if not rn.IsPlaying then
			playonly(rn)
		end
	elseif mv then
		hum.WalkSpeed = 19
		ts:Create(cam,TweenInfo.new(0.25),{FieldOfView=70}):Play()

		if not wa.IsPlaying then
			playonly(wa)
		end
	else
		hum.WalkSpeed = 19
		ts:Create(cam,TweenInfo.new(0.25),{FieldOfView=70}):Play()

		t += dt

		if t >= nxt and not i2.IsPlaying then
			t = 0
			nxt = math.random(7,14)

			i2:Play(0.1)

			task.spawn(function()
				task.wait(i2.Length > 0 and i2.Length or 2)
